APP_NAME=SpotexCMS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

ADMIN_NAME=Admin
ADMIN_EMAIL=admin@spotex.test
ADMIN_PASSWORD=password
ADMIN_ROLE=owner
USER_INVITATION_EXPIRES_HOURS=72

APP_LOCALE=it
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=it_IT

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=deprecations
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=spotex
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_COOKIE=spotex_customer_session
ADMIN_SESSION_COOKIE=spotex_admin_session

VITE_APP_NAME="Spotex CMS"

STRIPE_PUBLIC_KEY=pk_test_YOUR_KEY_HERE
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID_HERE
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET_HERE
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=YOUR_WEBHOOK_ID_HERE

SPOTEX_PLATFORM_MODE=off

# Tenancy (Shopify-like rollout)
SPOTEX_TENANCY_BASE_DOMAIN=
SPOTEX_TENANCY_PATH_PREFIX_ENABLED=true
SPOTEX_TENANCY_PATH_PREFIX=s
SPOTEX_TENANCY_ALLOW_HEADER_RESOLUTION=true
SPOTEX_TENANCY_FALLBACK_TO_DEFAULT_STORE=true
SPOTEX_INVENTORY_RESERVATION_TTL_MINUTES=15
SPOTEX_API_V1_TOKENS=
SPOTEX_API_V1_DEFAULT_PER_PAGE=20
SPOTEX_API_V1_MAX_PER_PAGE=100
SPOTEX_API_V1_OAUTH_ACCESS_TOKEN_TTL_MINUTES=120
SPOTEX_API_V1_OAUTH_ALLOWED_SCOPES=read_profile,read_products,write_products,read_inventory,write_inventory,read_orders,write_orders,read_customers,write_customers
SPOTEX_API_V1_PRIVATE_KEY_PREFIX=stx_pk_
SPOTEX_API_V1_IDEMPOTENCY_ENABLED=true
SPOTEX_API_V1_IDEMPOTENCY_HEADER=Idempotency-Key
SPOTEX_API_V1_IDEMPOTENCY_REQUIRED_METHODS=POST,PATCH,PUT
SPOTEX_API_V1_IDEMPOTENCY_TTL_HOURS=24
SPOTEX_API_V1_IDEMPOTENCY_KEY_MAX_LENGTH=255
SPOTEX_DEFAULT_ACCOUNT_NAME="Default Merchant Account"
SPOTEX_DEFAULT_STORE_NAME="Default Store"
SPOTEX_DEFAULT_STORE_SLUG=default
STRIPE_PLATFORM_SECRET=sk_test_YOUR_PLATFORM_SECRET
PAYPAL_PARTNER_CLIENT_ID=YOUR_PARTNER_CLIENT_ID
PAYPAL_PARTNER_SECRET=YOUR_PARTNER_SECRET
